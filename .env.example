# App
APP_HOST=0.0.0.0
APP_PORT=8443
APP_TITLE=Majic Movie Selector

# Optional TMDB integration for upcoming films
TMDB_API_KEY=
ROTTENTOMATOES_LIST_URL=https://www.rottentomatoes.com/browse/movies_at_home/sort:popular
RELEASES_URL=https://www.releases.com/calendar/movie
ROGEREBERT_REVIEWS_URL=https://www.rogerebert.com/reviews

# Plex integration
PLEX_BASE_URL=http://localhost:32400
PLEX_TOKEN=

# Radarr integration
RADARR_BASE_URL=http://localhost:7878
RADARR_API_KEY=

# NZBGeek RSS integration
NZBGEEK_RSS_URL=https://api.nzbgeek.info/api?t=search&cat=2000&apikey={API_KEY}
NZBGEEK_API_KEY=

# DrunkenSlug indexer integration
DRUNKENSLUG_BASE_URL=https://api.drunkenslug.com
DRUNKENSLUG_API_KEY=

# Usenet/NZBHydra2 integration
USENET_BASE_URL=http://localhost:5076
USENET_API_KEY=

# Ollama LLM integration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# FanArt.tv poster images (optional, improves poster coverage)
# Get free key at: https://fanart.tv/get-an-api-key/
FANART_API_KEY=

# Trakt.tv integration (optional, syncs watchlist/history/ratings)
# Register app at: https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_ACCESS_TOKEN=

# Push notifications via ntfy.sh (free, no account needed)
# Install ntfy on iOS/Android and subscribe to your topic
NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh

# Weekly digest email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_EMAIL=
# Webhook for OpenClaw/Hermes/n8n/Zapier integration
DIGEST_WEBHOOK_URL=

# Authentication
JWT_SECRET=

# Google OAuth (optional - enables "Sign in with Google")
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://0.0.0.0:8443/api/auth/google/callback
